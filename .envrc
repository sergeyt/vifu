# shellcheck shell=bash
# direnv: auto-sync uv venv and expose CLI on PATH

if ! has uv; then
  log_error "uv is required: https://docs.astral.sh/uv/"
  return 1
fi

# Re-sync when lockfile or pyproject changes (quiet on repeat cd)
watch_file pyproject.toml uv.lock .python-version
if ! uv sync --quiet 2>/dev/null; then
  uv sync
fi

export VIRTUAL_ENV="$PWD/.venv"
PATH_add "$VIRTUAL_ENV/bin"

# Personal clip/names — copy .envrc.local.example → .envrc.local
# (run.sh has its own defaults; only set INPUT here if you want to override)
source_env_if_exists .envrc.local
