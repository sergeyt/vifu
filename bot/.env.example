# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Path to vifu repo root (parent of bot/ by default)
VIFU_ROOT=..

# Optional: webhook URL base (e.g. https://bot.example.com). Unset = long polling.
# BOT_PUBLIC_URL=
# PORT=8787

# Max upload size in MB
MAX_VIDEO_MB=20

# Max clip length in seconds (rally clips ~10–30s)
MAX_VIDEO_SECONDS=30

# Render queue (free VM: keep 1 concurrent, ~3 total jobs)
MAX_CONCURRENT_RENDERS=1
MAX_RENDER_QUEUE=3

# Persistent queue DB + uploaded videos (survives restart/re-deploy when mounted)
# DATA_DIR=./data

# Optional: your Telegram user/chat id — DM when someone new uses the bot
# Get yours: message @userinfobot or send /start to your bot and check logs
# ADMIN_CHAT_ID=123456789

# Optional: Sentry error reporting (https://sentry.io)
# SENTRY_DSN=https://...@....ingest.sentry.io/...
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0
